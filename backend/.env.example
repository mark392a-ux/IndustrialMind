# LLM Keys
# Groq — FREE, no payment needed: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# DeepSeek R1 — FREE (generous limits): https://platform.deepseek.com
# Used for: RCA synthesis + compliance analysis (superior chain-of-thought reasoning)
# Falls back to Groq automatically if not set
DEEPSEEK_API_KEY=your_deepseek_key_here

# Cohere — FREE tier (1000 calls/month): https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_key_here

# Gemini API KEY
GEMINI_API_KEY=your_gemini_key_here

# App
APP_ENV=development
SECRET_KEY=changeme_in_production

# Paths
CHROMA_PERSIST_PATH=./data/chroma
GRAPH_PERSIST_PATH=./data/graph.pkl
UPLOAD_PATH=./data/uploads
EVAL_PATH=./eval
